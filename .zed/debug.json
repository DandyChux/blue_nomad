// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
	{
		"label": "Launch Chromee (TypeScript)",
		"adapter": "JavaScript",
		"type": "pwa-chrome",
		"request": "launch",
		"url": "http://localhost:3001",
		"program": "$ZED_FILE",
		"webRoot": "${ZED_WORKTREE_ROOT}",
		"sourceMaps": true,
		"build": {
			"command": "npx",
			"args": [
				"tsc"
			]
		}
	},
	{
		"label": "Launch Go (Delve)",
		"adapter": "Delve",
		"program": "${ZED_WORKTREE_ROOT}/api/main.go",
		"request": "launch",
		"mode": "debug",
		"cwd": "${ZED_WORKTREE_ROOT}/api"
	}
]
